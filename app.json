{
  "expo": {
    "name": "Hidro Scan",
    "slug": "hidro-scan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "scheme": "hidroscan",
    "backgroundColor": "#FAFAFA",
    "ios": {
      "bundleIdentifier": "com.hidroscan.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hidroscan.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "O Hidro Scan usa a câmera para fotografar a tira de teste e ler o pH.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "28.1.13356709"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
